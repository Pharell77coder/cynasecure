{# templates/admin/user/edit.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Modifier — {{ user.email }}{% endblock %}

{% block body %}
<div class="container py-4" style="max-width: 640px">

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin_users_index') }}">Utilisateurs</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin_users_show', {id: user.id}) }}">{{ user.email }}</a></li>
            <li class="breadcrumb-item active">Modifier</li>
        </ol>
    </nav>

    <div class="card shadow-sm">
        <div class="card-header fw-semibold">Modifier l'utilisateur #{{ user.id }}</div>
        <div class="card-body">
            {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
                {{ form_row(form.email) }}
                {{ form_row(form.roles) }}
                <hr>
                <p class="text-muted small mb-2">Laissez vide pour conserver le mot de passe actuel.</p>
                {{ form_row(form.plainPassword.first) }}
                {{ form_row(form.plainPassword.second) }}
                <div class="d-flex justify-content-between mt-3">
                    <a href="{{ path('admin_users_index') }}" class="btn btn-secondary">Annuler</a>
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>

</div>
{% endblock %}
